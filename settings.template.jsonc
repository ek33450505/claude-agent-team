// Claude Code Settings Template
// Copy this to ~/.claude/settings.local.json (remove comments or rename to .jsonc)
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  // Environment variables that enable experimental features
  // NOTE: CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS is required for agent spawning.
  // If a future Claude Code release removes or renames this flag, agents will
  // still work as regular markdown prompts — they just won't spawn as teammates.
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",  // Enable agent teams (teammate spawning)
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"        // Auto-compact context at 80% capacity
  },

  // Tool permissions — what Claude Code can do without asking
  // ⚠️  REVIEW CAREFULLY before merging into your settings.
  // These permissions let Claude Code run commands, create files, and edit files
  // WITHOUT prompting you first. Remove any you're not comfortable with.
  // A safer starting point: remove "Bash", "Write", "Edit" and let Claude ask each time.
  "permissions": {
    "allow": [
      "Bash",                                        // Run shell commands (remove for manual approval)
      "Write",                                       // Create new files (remove for manual approval)
      "Edit",                                        // Modify existing files (remove for manual approval)
      "WebSearch",                                   // Search the web
      "WebFetch(domain:github.com)",                 // Fetch from GitHub
      "WebFetch(domain:raw.githubusercontent.com)",   // Fetch raw GitHub content
      "WebFetch(domain:api.github.com)"              // Use GitHub API
    ]
  },

  // Hooks — scripts that run automatically at specific lifecycle points
  "hooks": {
    // Before every tool call: audit log (Phase 7f). Observation only — never blocks.
    // Writes one JSONL line per tool call to ~/.claude/logs/audit.jsonl.
    // Use `cast audit` (Phase 7e) to query the log.
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/cast-audit-hook.sh"
          }
        ],
        "description": "CAST Phase 7f audit hook — logs all tool calls to ~/.claude/logs/audit.jsonl"
      }
    ],
    // After Write or Edit: auto-format with prettier if the project supports it
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/auto-format.sh",
            "timeout": 10
          }
        ],
        "description": "Auto-format JS/TS/CSS files after Write/Edit if prettier is configured"
      }
    ],
    // Before Claude stops: nudge to verify tests/build if code was changed
    // Also: chain-reporter auto-dispatch after multi-batch orchestrator sessions
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Before completing: if code was modified but no tests were run, suggest running them. If a build-breaking change was made, suggest verifying the build. Otherwise, allow completion."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/stop-hook.sh",
            "timeout": 5
          }
        ],
        "description": "Verification nudge before completion; auto-dispatches chain-reporter after multi-batch orchestrator sessions"
      }
    ]
  },

  // Agent teams run in-process (same session) rather than spawning subprocesses
  "teammateMode": "in-process",

  // Update channel for Claude Code CLI
  "autoUpdatesChannel": "stable",

  // Where implementation plans are stored
  "plansDirectory": "~/.claude/plans/",

  // Worktree settings — symlink these dirs instead of copying (saves disk space)
  "worktree": {
    "symlinkDirectories": ["node_modules", ".cache", "dist"]
  },

  // Sandbox restricts file and network access for safety
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,              // Don't prompt for Bash if sandboxed
    "excludedCommands": ["git", "docker", "bq", "osascript"],  // These bypass sandbox
    "filesystem": {
      "denyRead": ["~/.aws/credentials", "~/.ssh/id_*", "~/.gnupg"],  // Never read secrets
      "allowWrite": ["/tmp"]                        // Only allow writes to /tmp (plus project dir)
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "*.googleapis.com",
        "api.anthropic.com"
      ],
      "allowLocalBinding": true                     // Allow localhost servers (dev servers, etc.)
    }
  }
}
