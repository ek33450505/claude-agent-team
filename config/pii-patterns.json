{
  "version": "1.0",
  "description": "Custom PII patterns for cast-redact.py. Add project-specific identifiers here. Each pattern adds a custom recognizer on top of Presidio's built-in entity detection.",
  "patterns": [
    {
      "name": "API_KEY_ASSIGNMENT",
      "entity_type": "API_KEY",
      "description": "API key appearing as an assignment or header value",
      "regex": "(?i)(?:api[_-]?key|apikey|x-api-key|access[_-]?key)[\\s:=]+['\"]?([A-Za-z0-9_\\-]{20,})['\"]?",
      "group": 1,
      "score": 0.9
    },
    {
      "name": "BEARER_TOKEN",
      "entity_type": "BEARER_TOKEN",
      "description": "HTTP Authorization Bearer token",
      "regex": "(?i)bearer\\s+([A-Za-z0-9_\\-\\.]{20,})",
      "group": 1,
      "score": 0.95
    },
    {
      "name": "PRIVATE_KEY_PEM",
      "entity_type": "PRIVATE_KEY",
      "description": "PEM-encoded private key header/footer",
      "regex": "-----BEGIN[A-Z ]+(?:PRIVATE KEY|CERTIFICATE)-----",
      "score": 1.0
    },
    {
      "name": "AWS_ACCESS_KEY_ID",
      "entity_type": "AWS_ACCESS_KEY",
      "description": "AWS access key ID (20 uppercase alphanumeric chars starting with AKIA)",
      "regex": "(?<![A-Z0-9])(AKIA[0-9A-Z]{16})(?![A-Z0-9])",
      "score": 0.99
    },
    {
      "name": "AWS_SECRET_ACCESS_KEY",
      "entity_type": "AWS_SECRET_KEY",
      "description": "AWS secret access key (40 base64 chars, context-dependent)",
      "regex": "(?i)(?:aws[_-]?secret|secret[_-]?access[_-]?key)[\\s:=]+['\"]?([A-Za-z0-9/+=]{40})['\"]?",
      "group": 1,
      "score": 0.9
    },
    {
      "name": "GITHUB_PAT",
      "entity_type": "GITHUB_TOKEN",
      "description": "GitHub personal access token (classic or fine-grained)",
      "regex": "(?:ghp|gho|ghu|ghs|ghr|github_pat)_[A-Za-z0-9_]{36,}",
      "score": 0.99
    },
    {
      "name": "ANTHROPIC_API_KEY",
      "entity_type": "ANTHROPIC_API_KEY",
      "description": "Anthropic API key",
      "regex": "sk-ant-[A-Za-z0-9_\\-]{32,}",
      "score": 1.0
    },
    {
      "name": "OPENAI_API_KEY",
      "entity_type": "OPENAI_API_KEY",
      "description": "OpenAI API key",
      "regex": "sk-(?:proj-)?[A-Za-z0-9]{32,}",
      "score": 0.95
    },
    {
      "name": "PRIVATE_IPV4",
      "entity_type": "INTERNAL_IP",
      "description": "Private/internal IPv4 ranges (RFC1918)",
      "regex": "\\b(?:10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}|172\\.(?:1[6-9]|2\\d|3[01])\\.\\d{1,3}\\.\\d{1,3}|192\\.168\\.\\d{1,3}\\.\\d{1,3})\\b",
      "score": 0.7
    },
    {
      "name": "JWT_TOKEN",
      "entity_type": "JWT",
      "description": "JSON Web Token (three base64url segments separated by dots)",
      "regex": "eyJ[A-Za-z0-9_\\-]+\\.eyJ[A-Za-z0-9_\\-]+\\.[A-Za-z0-9_\\-]+",
      "score": 0.98
    },
    {
      "name": "DATABASE_URL",
      "entity_type": "DATABASE_URL",
      "description": "Database connection string with embedded credentials",
      "regex": "(?i)(?:postgres|mysql|mongodb|redis|sqlite)(?:ql)?://[^:@\\s]+:[^@\\s]+@[^\\s]+",
      "score": 0.95
    }
  ]
}
