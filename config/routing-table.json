{
  "routes": [
    {
      "patterns": ["write test", "add test", "tests for", "test coverage", "failing test", "vitest", "jest"],
      "agent": "test-writer",
      "command": "/test"
    },
    {
      "patterns": ["commit", "git commit", "stage and commit", "create a commit"],
      "agent": "commit",
      "command": "/commit"
    },
    {
      "patterns": ["fix.*bug", "debug", "why.*failing", "what.*error", "traceback", "stack trace", "not working"],
      "agent": "debugger",
      "command": "/debug"
    },
    {
      "patterns": ["review.*code", "code review", "check.*changes", "look.*over"],
      "agent": "code-reviewer",
      "command": "/review"
    },
    {
      "patterns": ["plan.*implement", "implementation plan", "how.*should.*build", "design.*feature", "architect"],
      "agent": "planner",
      "command": "/plan"
    },
    {
      "patterns": ["write.*docs", "update.*readme", "update.*changelog", "add.*jsdoc", "document"],
      "agent": "doc-updater",
      "command": "/docs"
    },
    {
      "patterns": ["security.*review", "check.*vulnerabilit", "owasp", "sql injection", "xss"],
      "agent": "security",
      "command": "/secure"
    },
    {
      "patterns": ["refactor", "dead code", "clean up", "unused import"],
      "agent": "refactor-cleaner",
      "command": "/refactor"
    },
    {
      "patterns": ["research", "compare.*librar", "evaluate.*tool", "which.*framework"],
      "agent": "researcher",
      "command": "/research"
    }
  ],
  "opus_signals": {
    "prefix": "opus:",
    "complexity_patterns": [
      "design the entire",
      "analyze the whole codebase",
      "think through.*architecture",
      "system design",
      "1m context"
    ]
  }
}
