{
  "routes": [
    {
      "patterns": [
        "write.*test",
        "add.*test",
        "test.*for",
        "test coverage",
        "test.*fail|fail.*test",
        "vitest",
        "jest",
        "need.*test",
        "test.*coverage",
        "should.*test"
      ],
      "agent": "test-writer",
      "command": "/test",
      "post_chain": [
        "commit"
      ]
    },
    {
      "patterns": [
        "^commit$",
        "^/commit\\b",
        "git commit",
        "^push$",
        "^git push",
        "stage and commit",
        "create a commit",
        "make a commit",
        "need to commit"
      ],
      "agent": "commit",
      "command": "/commit",
      "post_chain": null
    },
    {
      "patterns": [
        "fix.*bug",
        "debug",
        "why.*failing",
        "what.*error",
        "traceback",
        "stack trace",
        "not working",
        "\\bbroken\\b",
        "quick.*fix",
        "quickfix",
        "not.*showing",
        "what.*wrong",
        "doesn't.*work",
        "issue with"
      ],
      "agent": "debugger",
      "command": "/debug",
      "post_chain": [
        "code-reviewer",
        "commit"
      ]
    },
    {
      "patterns": [
        "^/review\\b",
        "^/code-review\\b",
        "review.*code",
        "code review",
        "check.*changes",
        "look.*over",
        "before we push",
        "check.*code",
        "look.*at.*changes"
      ],
      "agent": "code-reviewer",
      "command": "/review",
      "post_chain": [
        "commit"
      ]
    },
    {
      "patterns": [
        "^/plan\\b",
        "plan.*implement",
        "implementation plan",
        "how.*should.*build",
        "design.*feature",
        "architect",
        "create.*agent",
        "add.*agent",
        "new.*agent",
        "wrap.*up",
        "finish.*up",
        "finalize",
        "let's build",
        "add.*feature",
        "implement",
        "we need to",
        "i want to",
        "how should we"
      ],
      "agent": "planner",
      "command": "/plan",
      "post_chain": [
        "auto-dispatch-from-manifest"
      ]
    },
    {
      "patterns": [
        "write.*docs",
        "update.*readme",
        "ensure.*readme",
        "verify.*readme",
        "readme.*accurate",
        "readme.*describes",
        "check.*readme",
        "update.*changelog",
        "add.*jsdoc",
        "document",
        "update.*doc",
        "fix.*readme",
        "readme.*wrong"
      ],
      "agent": "doc-updater",
      "command": "/docs",
      "post_chain": [
        "commit"
      ]
    },
    {
      "patterns": [
        "security.*review",
        "check.*vulnerabilit",
        "owasp",
        "sql injection",
        "xss"
      ],
      "agent": "security",
      "command": "/secure",
      "post_chain": null
    },
    {
      "patterns": [
        "refactor",
        "dead code",
        "clean up",
        "unused import"
      ],
      "agent": "refactor-cleaner",
      "command": "/refactor",
      "post_chain": [
        "code-reviewer",
        "commit"
      ]
    },
    {
      "patterns": [
        "research",
        "compare.*librar",
        "evaluate.*tool",
        "which.*framework"
      ],
      "agent": "researcher",
      "command": "/research",
      "post_chain": null
    },
    {
      "patterns": [
        "e2e test",
        "playwright",
        "end.to.end",
        "integration test"
      ],
      "agent": "e2e-runner",
      "command": "/e2e",
      "post_chain": null
    },
    {
      "patterns": [
        "build.*error",
        "typescript error",
        "eslint.*error",
        "tsc.*fail",
        "vite.*error"
      ],
      "agent": "build-error-resolver",
      "command": "/build-fix",
      "post_chain": [
        "commit"
      ]
    },
    {
      "patterns": [
        "slide deck",
        "create.*presentation",
        "create.*slides",
        "status.*deck"
      ],
      "agent": "presenter",
      "command": "/present",
      "post_chain": null
    },
    {
      "patterns": [
        "morning briefing",
        "daily briefing",
        "what.*on.*today",
        "my schedule"
      ],
      "agent": "morning-briefing",
      "command": "/morning",
      "post_chain": null
    }
  ],
  "opus_signals": {
    "prefix": "opus:",
    "complexity_patterns": [
      "design the entire",
      "analyze the whole codebase",
      "think through.*architecture",
      "system design",
      "1m context"
    ]
  }
}
