{
  "routes": [
    {
      "patterns": [
        "^/push\\b", "^push$", "git push", "push.*remote", "push.*origin",
        "push.*branch", "push the code", "push.*commit", "push.*changes"
      ],
      "agent": "push",
      "model": "haiku",
      "command": "/push",
      "confidence": "hard",
      "post_chain": []
    },
    {
      "patterns": [
        "build.*error", "typescript.*error", "eslint.*error", "tsc.*fail",
        "vite.*error", "^/build-fix\\b", "build.*fail", "compile.*error",
        "type.*error.*in", "module.*not found", "import.*error", "cannot find module"
      ],
      "agent": "build-error-resolver",
      "model": "haiku",
      "command": "/build-fix",
      "confidence": "hard",
      "post_chain": ["commit"]
    },
    {
      "patterns": ["e2e test", "integration test", "playwright", "end.to.end", "^/e2e\\b"],
      "agent": "e2e-runner",
      "model": "sonnet",
      "command": "/e2e",
      "confidence": "hard",
      "post_chain": null
    },
    {
      "patterns": ["write.*test", "add.*test", "test.*for", "test coverage", "test.*fail|fail.*test", "vitest", "jest", "need.*test", "test.*coverage", "should.*test", "missing.*test", "no.*test"],
      "agent": "test-writer",
      "model": "sonnet",
      "command": "/test",
      "confidence": "hard",
      "post_chain": ["code-reviewer", "commit"]
    },
    {
      "patterns": ["^commit$", "^/commit\\b", "git commit", "^push$", "^git push", "stage and commit", "create a commit", "make a commit", "need to commit"],
      "agent": "commit",
      "model": "haiku",
      "command": "/commit",
      "confidence": "hard",
      "post_chain": null
    },
    {
      "patterns": [
        "fix.*bug", "\\bdebugg?ing\\b", "debug this", "debug the", "why.*failing", "what.*error",
        "traceback", "stack trace",
        "\\bnot working\\b(?! on)", "\\bbroken\\b", "quick.*fix", "quickfix", "not.*showing",
        "what.*wrong", "doesn't.*work", "issue with",
        "is broken", "page.*broken", "not.*correct", "something.*wrong",
        "\\bexception\\b", "\\bcrash\\b", "\\bfails\\b", "\\bfailing\\b",
        "won'?t work", "getting an error",
        "\\bTypeError\\b", "\\bReferenceError\\b", "\\bstuck\\b",
        "can you fix", "please fix", "can'?t.*load",
        "blank.*screen", "white.*screen", "console.*error",
        "(it|this|that).*(broken|not working|wrong)",
        "nothing.*happen", "unexpected.*behav"
      ],
      "agent": "debugger",
      "model": "sonnet",
      "command": "/debug",
      "confidence": "hard",
      "post_chain": ["code-reviewer"]
    },
    {
      "patterns": ["^/review\\b", "^/code-review\\b", "review.*code", "code review", "check.*changes", "look.*over", "before we push", "check.*code", "look.*at.*changes", "review.*pr", "pr review"],
      "agent": "code-reviewer",
      "model": "haiku",
      "command": "/review",
      "confidence": "hard",
      "post_chain": null
    },
    {
      "patterns": [
        "^/plan\\b", "plan.*implement", "implementation plan", "how.*should.*build",
        "design.*feature", "create.*agent", "add.*agent", "new.*agent",
        "let's build", "add.*feature",
        "^implement\\b", "^create a\\b", "^build\\b",
        "i want to (add|build|create)", "let'?s (add|build|create|implement)",
        "^add.*page", "^add.*route", "^add.*endpoint",
        "add support for", "build.*feature",
        "^add.*to the (app|project|codebase|system|dashboard|page|route|api)",
        "^add a (new\\b|component|hook|util|service|feature)",
        "^create a new\\b", "^we need to\\b"
      ],
      "agent": "planner",
      "model": "sonnet",
      "command": "/plan",
      "confidence": "soft",
      "post_chain": ["orchestrator"]
    },
    {
      "patterns": ["write.*docs", "update.*readme", "ensure.*readme", "verify.*readme", "readme.*accurate", "readme.*describes", "check.*readme", "update.*changelog", "add.*jsdoc", "document.*the", "update.*doc", "fix.*readme", "fix.*docs", "fix.*documentation", "readme.*wrong", "^/docs\\b"],
      "agent": "doc-updater",
      "model": "haiku",
      "command": "/docs",
      "confidence": "hard",
      "post_chain": ["commit"]
    },
    {
      "patterns": ["security.*review", "check.*vulnerabilit", "owasp", "sql injection", "xss", "^/secure\\b", "security.*audit"],
      "agent": "security",
      "model": "sonnet",
      "command": "/secure",
      "confidence": "hard",
      "post_chain": null
    },
    {
      "patterns": ["\\barchitecture\\b", "how should.*structured", "best.*approach.*for", "trade.?off", "\\bADR\\b", "design.*decision", "module.*boundar", "should we use", "which.*approach", "evaluate.*option", "^/architect\\b"],
      "agent": "architect",
      "model": "sonnet",
      "command": "/architect",
      "confidence": "hard",
      "post_chain": null
    },
    {
      "patterns": ["refactor", "dead code", "clean up", "unused import", "^/refactor\\b", "simplify.*code", "reduce.*complexity"],
      "agent": "refactor-cleaner",
      "model": "haiku",
      "command": "/refactor",
      "confidence": "hard",
      "post_chain": ["code-reviewer", "commit"]
    },
    {
      "patterns": ["\\bresearch\\b.*(this|pattern|option|tool|library|approach|alternative|framework)", "compare.*librar", "evaluate.*tool", "which.*framework", "^/research\\b", "pros.*cons", "alternative.*to"],
      "agent": "researcher",
      "model": "sonnet",
      "command": "/research",
      "confidence": "soft",
      "post_chain": null
    },
    {
      "patterns": ["slide deck", "create.*presentation", "create.*slides", "status.*deck", "^/present\\b"],
      "agent": "presenter",
      "model": "sonnet",
      "command": "/present",
      "confidence": "hard",
      "post_chain": null
    },
    {
      "patterns": ["morning briefing", "daily briefing", "what.*on.*today", "my schedule", "^/morning\\b"],
      "agent": "morning-briefing",
      "model": "sonnet",
      "command": "/morning",
      "confidence": "hard",
      "post_chain": null
    },
    {
      "patterns": ["^/data\\b", "analyze.*data", "data.*analysis", "bigquery", "\\bbq\\b.*query"],
      "agent": "data-scientist",
      "model": "sonnet",
      "command": "/data",
      "confidence": "hard",
      "post_chain": null
    },
    {
      "patterns": ["^/query\\b", "run.*query", "select.*from", "sql.*query"],
      "agent": "db-reader",
      "model": "haiku",
      "command": "/query",
      "confidence": "hard",
      "post_chain": null
    },
    {
      "patterns": ["^/email\\b", "check.*email", "\\binbox\\b", "draft.*email", "reply.*to.*(email|message|thread|sender)"],
      "agent": "email-manager",
      "model": "sonnet",
      "command": "/email",
      "confidence": "hard",
      "post_chain": null
    },
    {
      "patterns": ["^/qa\\b", "qa review", "quality.*check", "second.*opinion"],
      "agent": "qa-reviewer",
      "model": "sonnet",
      "command": "/qa",
      "confidence": "soft",
      "post_chain": null
    },
    {
      "patterns": ["^/readme\\b", "rewrite.*readme", "readme.*audit"],
      "agent": "readme-writer",
      "model": "sonnet",
      "command": "/readme",
      "confidence": "hard",
      "post_chain": ["commit"]
    },
    {
      "patterns": ["generate.*report", "write.*report", "status.*report", "project.*report", "sprint.*report", "^/report\\b"],
      "agent": "report-writer",
      "model": "haiku",
      "command": "/report",
      "confidence": "hard",
      "post_chain": null
    },
    {
      "patterns": ["meeting notes", "process.*meeting", "meeting.*transcript", "extract.*action items", "action items.*from", "^/meeting\\b"],
      "agent": "meeting-notes",
      "model": "haiku",
      "command": "/meeting",
      "confidence": "hard",
      "post_chain": null
    }
  ],
  "opus_signals": {
    "prefix": "opus:",
    "complexity_patterns": [
      "design the entire",
      "analyze the whole codebase",
      "think through.*architecture",
      "system design",
      "1m context"
    ]
  }
}
