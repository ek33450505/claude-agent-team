#!/usr/bin/env bash
# cast — CAST CLI (v4 rebuild)
# Main entrypoint for all cast subcommands.
#
# Usage: cast <subcommand> [args] [--json] [--quiet] [--verbose]
#
# Subcommands: status, exec, memory, budget, agents, hooks, doctor, install-completions
#
# Config: ~/.claude/config/cast-cli.json
# DB:     $CAST_DB_PATH or ~/.claude/cast.db

set -uo pipefail

# ── Script directory (resolve symlinks) ──────────────────────────────────────
CAST_BIN_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")" && pwd)"
CAST_REPO_DIR="$(cd "$CAST_BIN_DIR/.." && pwd)"

# ── Version ──────────────────────────────────────────────────────────────────
CAST_VERSION="$(cat "${CAST_REPO_DIR}/VERSION" 2>/dev/null || echo "unknown")"
CAST_SCRIPTS_DIR="${HOME}/.claude/scripts"
CAST_AGENTS_DIR="${HOME}/.claude/agents"

# ── Global flags ─────────────────────────────────────────────────────────────
CAST_JSON=0
CAST_QUIET=0
CAST_VERBOSE=0

# ── Load config ──────────────────────────────────────────────────────────────
CAST_CONFIG_FILE="${HOME}/.claude/config/cast-cli.json"

_config_get() {
  local key="$1"
  local default="${2:-}"
  if [ -f "$CAST_CONFIG_FILE" ] && command -v python3 >/dev/null 2>&1; then
    python3 -c "
import json, sys
try:
    with open('$CAST_CONFIG_FILE') as f:
        cfg = json.load(f)
    val = cfg.get('$key', '$default')
    if val:
        print(str(val).replace('~', __import__('os').path.expanduser('~')))
    else:
        print('$default')
except Exception:
    print('$default')
" 2>/dev/null || echo "$default"
  else
    echo "$default"
  fi
}

# Resolve DB path: env var > config file > default
if [ -z "${CAST_DB_PATH:-}" ]; then
  _cfg_db="$(_config_get db_path "${HOME}/.claude/cast.db")"
  CAST_DB_PATH="${_cfg_db:-${HOME}/.claude/cast.db}"
fi
export CAST_DB_PATH

# ── Colors ───────────────────────────────────────────────────────────────────
if [ -t 1 ] && [ "${TERM:-}" != "dumb" ]; then
  C_BOLD='\033[1m'
  C_GREEN='\033[0;32m'
  C_YELLOW='\033[0;33m'
  C_CYAN='\033[0;36m'
  C_RED='\033[0;31m'
  C_DIM='\033[2m'
  C_RESET='\033[0m'
else
  C_BOLD='' C_GREEN='' C_YELLOW='' C_CYAN='' C_RED='' C_DIM='' C_RESET=''
fi

# ── Helpers ──────────────────────────────────────────────────────────────────
_info()    { [ "$CAST_QUIET" -eq 0 ] && printf "${C_CYAN}%s${C_RESET}\n" "$*"; }
_success() { [ "$CAST_QUIET" -eq 0 ] && printf "${C_GREEN}%s${C_RESET}\n" "$*"; }
_warn()    { printf "${C_YELLOW}%s${C_RESET}\n" "$*" >&2; }
_error()   { printf "${C_RED}Error: %s${C_RESET}\n" "$*" >&2; }
_verbose() { [ "$CAST_VERBOSE" -eq 1 ] && printf "${C_DIM}[verbose] %s${C_RESET}\n" "$*" >&2; }

_require_db() {
  if [ ! -f "$CAST_DB_PATH" ]; then
    _error "cast.db not found at $CAST_DB_PATH"
    printf "  Run: bash %s/cast-db-init.sh\n" "$CAST_SCRIPTS_DIR" >&2
    exit 1
  fi
  if ! command -v sqlite3 >/dev/null 2>&1; then
    _error "sqlite3 not found in PATH"
    exit 1
  fi
}

_db() {
  sqlite3 "$CAST_DB_PATH" "$@"
}

_parse_global_flags() {
  local remaining=()
  while [ "${#}" -gt 0 ]; do
    case "$1" in
      --json)     CAST_JSON=1; shift ;;
      --quiet)    CAST_QUIET=1; shift ;;
      --verbose)  CAST_VERBOSE=1; shift ;;
      --help|-h)
        _usage
        exit 0
        ;;
      --version)
        echo "cast version ${CAST_VERSION}"
        exit 0
        ;;
      *)
        remaining+=("$1")
        shift
        ;;
    esac
  done
  if [ "${#remaining[@]}" -gt 0 ]; then
    CAST_ARGS=("${remaining[@]}")
  else
    CAST_ARGS=()
  fi
}

# ── Usage ────────────────────────────────────────────────────────────────────
_usage() {
  cat <<USAGE
${C_BOLD}CAST v${CAST_VERSION}${C_RESET}

Usage: cast <subcommand> [args] [flags]

Subcommands:
  ${C_BOLD}status${C_RESET}                          Terminal health dashboard
  ${C_BOLD}exec${C_RESET}      [--resume|--status] <plan>  Execute a plan manifest
  ${C_BOLD}memory${C_RESET}    search|list|forget|export   Query and manage agent memories
  ${C_BOLD}budget${C_RESET}    [--week] [--project]        View cost summary
  ${C_BOLD}agents${C_RESET}                          List installed CAST agents
  ${C_BOLD}hooks${C_RESET}                           Show active hooks with health status
  ${C_BOLD}doctor${C_RESET}                          Run system health check
  ${C_BOLD}install-completions${C_RESET}             Install shell tab completions

Global flags:
  --json        Machine-readable JSON output
  --quiet       Suppress informational messages
  --verbose     Show debug details
  --help, -h    Show this help
  --version     Show version

Config: ${CAST_CONFIG_FILE}
DB:     ${CAST_DB_PATH}
USAGE
}

# ── Subcommand: status ───────────────────────────────────────────────────────
_cmd_status() {
  local width=50
  if command -v tput >/dev/null 2>&1; then
    width="$(tput cols 2>/dev/null || echo 50)"
  fi
  if [ "$width" -gt 70 ]; then width=70; fi

  # Budget
  local today_spend=0 week_spend=0
  if [ -f "$CAST_DB_PATH" ] && command -v python3 >/dev/null 2>&1; then
    read -r today_spend week_spend <<< "$(python3 - "$CAST_DB_PATH" <<'PYEOF'
import sys, sqlite3
from datetime import datetime, timedelta, timezone
db = sys.argv[1]
conn = sqlite3.connect(db)
cur = conn.cursor()
today = datetime.now(timezone.utc).strftime('%Y-%m-%d')
week_ago = (datetime.now(timezone.utc)-timedelta(days=7)).strftime('%Y-%m-%d')
cur.execute("SELECT COALESCE(SUM(cost_usd),0) FROM agent_runs WHERE DATE(started_at)=?", (today,))
today_s = cur.fetchone()[0] or 0
cur.execute("SELECT COALESCE(SUM(cost_usd),0) FROM agent_runs WHERE DATE(started_at)>=?", (week_ago,))
week_s = cur.fetchone()[0] or 0
conn.close()
print(f"{today_s:.2f} {week_s:.2f}")
PYEOF
    2>/dev/null || echo "0.00 0.00")"
  fi

  # Memory count
  local mem_count=0
  if [ -f "$CAST_DB_PATH" ] && command -v sqlite3 >/dev/null 2>&1; then
    mem_count="$(sqlite3 "$CAST_DB_PATH" "SELECT COUNT(*) FROM agent_memories;" 2>/dev/null || echo 0)"
  fi

  # Agent count
  local agent_count=0
  if [ -d "$CAST_AGENTS_DIR" ]; then
    agent_count="$(ls "$CAST_AGENTS_DIR"/*.md 2>/dev/null | wc -l | tr -d ' ')"
  fi

  # Hook count
  local hook_count=0
  local settings_file="${HOME}/.claude/settings.json"
  if [ -f "$settings_file" ]; then
    hook_count="$(python3 -c "
import json
with open('$settings_file') as f:
    cfg = json.load(f)
hooks = cfg.get('hooks', {})
print(sum(len(v) if isinstance(v, list) else 1 for v in hooks.values()))
" 2>/dev/null || echo 0)"
  fi

  # Recent agent runs (last 5)
  local recent_runs=""
  if [ -f "$CAST_DB_PATH" ] && command -v python3 >/dev/null 2>&1; then
    recent_runs="$(python3 - "$CAST_DB_PATH" <<'PYEOF'
import sys, sqlite3
from datetime import datetime, timezone
db = sys.argv[1]
conn = sqlite3.connect(db)
conn.row_factory = sqlite3.Row
cur = conn.cursor()
cur.execute("""
    SELECT agent, status, model, ended_at, batch_id
    FROM agent_runs ORDER BY id DESC LIMIT 5
""")
rows = cur.fetchall()
conn.close()
now = datetime.now(timezone.utc)
for r in rows:
    ended = r['ended_at'] or ''
    ago = ''
    if ended:
        try:
            t = datetime.fromisoformat(ended.replace('Z','+00:00'))
            diff = int((now - t).total_seconds())
            if diff < 3600:
                ago = f"{diff//60}m ago"
            else:
                ago = f"{diff//3600}h ago"
        except:
            ago = ''
    status_sym = '+' if r['status'] == 'DONE' else ('x' if r['status'] in ('BLOCKED','NEEDS_CONTEXT') else '~')
    model = r['model'] or ''
    batch = f" [batch:{r['batch_id']}]" if r['batch_id'] else ''
    print(f"  {status_sym} {(r['agent'] or ''):<22} [{model:<24}] {ago}{batch}")
PYEOF
    2>/dev/null || echo "")"
  fi

  # Render dashboard
  local sep
  sep="$(python3 -c "print('=' * $width)" 2>/dev/null || printf '%0.s=' $(seq 1 $width))"

  printf "${C_BOLD}CAST v${CAST_VERSION}${C_RESET}\n"
  printf "%s\n" "$sep"
  printf "Agents      %d installed\n" "$agent_count"
  printf "Hooks       %d active\n" "$hook_count"
  printf "Budget      \$%s today  \$%s this week\n" "$today_spend" "$week_spend"
  printf "Memory      %d entries\n" "$mem_count"
  printf "%s\n" "$sep"

  if [ -n "$recent_runs" ]; then
    printf "Recent agents (last 5):\n"
    printf "%s\n" "$recent_runs"
  else
    printf "${C_DIM}No recent agent runs recorded.${C_RESET}\n"
  fi
}

# ── Subcommand: agents ───────────────────────────────────────────────────────
_cmd_agents() {
  if [ ! -d "$CAST_AGENTS_DIR" ]; then
    _error "Agents directory not found: $CAST_AGENTS_DIR"
    return 1
  fi

  python3 - "$CAST_AGENTS_DIR" "$CAST_JSON" <<'PYEOF'
import sys, os, json, re

agents_dir = sys.argv[1]
json_out = sys.argv[2] == "1"

agents = []
for fname in sorted(os.listdir(agents_dir)):
    if not fname.endswith('.md'):
        continue
    fpath = os.path.join(agents_dir, fname)
    try:
        with open(fpath, 'r') as f:
            content = f.read()
    except Exception:
        continue

    name = fname.replace('.md', '')
    model = ''
    description = ''

    # Parse YAML frontmatter
    if content.startswith('---'):
        parts = content.split('---', 2)
        if len(parts) >= 3:
            fm = parts[1]
            for line in fm.strip().split('\n'):
                line = line.strip()
                if line.startswith('model:'):
                    model = line.split(':', 1)[1].strip().strip('"').strip("'")
                elif line.startswith('description:'):
                    desc_val = line.split(':', 1)[1].strip()
                    if desc_val == '>':
                        continue
                    description = desc_val.strip('"').strip("'")
                elif not line.startswith(('name:', 'tools:', 'color:', 'memory:', 'maxTurns:', 'effort:')) and description == '' and ':' not in line and line:
                    # Continuation of multiline description
                    description = line.strip()

    agents.append({
        'name': name,
        'model': model or 'sonnet',
        'description': description[:80] if description else '',
    })

if json_out:
    print(json.dumps(agents, indent=2))
    sys.exit(0)

print(f"{'AGENT':<24} {'MODEL':<10} DESCRIPTION")
print("-" * 80)
for a in agents:
    print(f"{a['name']:<24} {a['model']:<10} {a['description']}")
print(f"\n{len(agents)} agents installed")
PYEOF
}

# ── Subcommand: hooks ────────────────────────────────────────────────────────
_cmd_hooks() {
  local settings_file="${HOME}/.claude/settings.json"
  if [ ! -f "$settings_file" ]; then
    _error "settings.json not found at $settings_file"
    return 1
  fi

  python3 - "$settings_file" "$CAST_JSON" <<'PYEOF'
import sys, json, os

settings_file = sys.argv[1]
json_out = sys.argv[2] == "1"

with open(settings_file) as f:
    cfg = json.load(f)

hooks_cfg = cfg.get("hooks", {})
entries = []

for event, hook_list in hooks_cfg.items():
    if not isinstance(hook_list, list):
        hook_list = [hook_list]
    for entry in hook_list:
        if not isinstance(entry, dict):
            continue
        hook_id = entry.get("id", "")
        matcher = entry.get("matcher", "")
        inner_hooks = entry.get("hooks", [])
        for h in inner_hooks:
            if not isinstance(h, dict):
                continue
            htype = h.get("type", "")
            cmd = h.get("command", h.get("url", h.get("prompt", "")))[:60]
            is_async = h.get("async", False)
            timeout = h.get("timeout", "")

            # Check if script exists
            health = "ok"
            if htype == "command" and cmd:
                parts = cmd.split()
                for part in parts:
                    if part in ("bash", "sh", "python3"):
                        continue
                    if part.startswith("-"):
                        continue
                    expanded = os.path.expanduser(part)
                    if "/" in expanded:
                        if not os.path.isfile(expanded):
                            health = "MISSING"
                        break

            entries.append({
                "event": event,
                "id": hook_id,
                "type": htype,
                "command": cmd,
                "async": is_async,
                "timeout": timeout,
                "matcher": matcher,
                "health": health,
            })

if json_out:
    print(json.dumps(entries, indent=2))
    sys.exit(0)

print(f"{'EVENT':<20} {'ID':<24} {'ASYNC':<6} {'HEALTH':<8} COMMAND")
print("-" * 100)
for e in entries:
    async_str = "yes" if e["async"] else "no"
    print(f"{e['event']:<20} {e['id']:<24} {async_str:<6} {e['health']:<8} {e['command']}")
print(f"\n{len(entries)} hook entries across {len(hooks_cfg)} event types")
PYEOF
}

# ── Subcommand: memory ───────────────────────────────────────────────────────
_cmd_memory() {
  local subcmd="${1:-list}"
  shift 2>/dev/null || true

  case "$subcmd" in
    search)  _memory_search "$@" ;;
    list)    _memory_list "$@" ;;
    forget)  _memory_forget "$@" ;;
    export)  _memory_export "$@" ;;
    --help|-h)
      cat <<USAGE
Usage: cast memory <subcommand> [args]

  search "<query>"  [--agent <name>] [--project <name>] [--limit 10]
  list              [--agent <name>] [--type feedback|project|user|reference]
  forget <id>
  export
USAGE
      ;;
    *)
      _error "Unknown memory subcommand: $subcmd"
      printf "  Use: cast memory search|list|forget|export\n" >&2
      return 1
      ;;
  esac
}

_memory_search() {
  local query=""
  local agent_filter=""
  local project_filter=""
  local limit=10

  while [ "${#}" -gt 0 ]; do
    case "$1" in
      --agent)    agent_filter="${2:-}"; shift 2 ;;
      --project)  project_filter="${2:-}"; shift 2 ;;
      --limit)    limit="${2:-10}"; shift 2 ;;
      *)
        if [ -z "$query" ]; then query="$1"; fi
        shift
        ;;
    esac
  done

  if [ -z "$query" ]; then
    _error "Usage: cast memory search \"<query>\" [--agent <name>] [--limit 10]"
    return 1
  fi

  local query_script="${CAST_SCRIPTS_DIR}/cast-memory-query.sh"
  if [ ! -f "$query_script" ]; then
    query_script="${CAST_REPO_DIR}/scripts/cast-memory-query.sh"
  fi

  if [ ! -f "$query_script" ]; then
    _error "cast-memory-query.sh not found"
    return 1
  fi

  local args=("$query" "--limit" "$limit")
  [ -n "$agent_filter" ]   && args+=("--agent"   "$agent_filter")
  [ -n "$project_filter" ] && args+=("--project" "$project_filter")

  local result
  result="$(bash "$query_script" "${args[@]}" 2>/dev/null || echo "[]")"

  if [ "$CAST_JSON" -eq 1 ]; then
    echo "$result"
    return 0
  fi

  python3 - "$result" <<'PYEOF'
import sys, json
try:
    rows = json.loads(sys.argv[1])
except Exception:
    rows = []
if not rows:
    print("No memories found.")
    sys.exit(0)
for r in rows:
    score = f"  [score:{r['score']:.2f}]" if 'score' in r else ""
    print(f"[{r['id']}] {r['agent']} / {r['type']} — {r['name']}{score}")
    content = (r['content'] or '')[:200]
    print(f"  {content}")
    print()
PYEOF
}

_memory_list() {
  _require_db

  local agent_filter=""
  local type_filter=""

  while [ "${#}" -gt 0 ]; do
    case "$1" in
      --agent) agent_filter="${2:-}"; shift 2 ;;
      --type)  type_filter="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done

  python3 - "$CAST_DB_PATH" "$agent_filter" "$type_filter" "$CAST_JSON" <<'PYEOF'
import sys, sqlite3, json

db_path, agent_f, type_f, json_mode = sys.argv[1:5]
json_out = json_mode == "1"

conn = sqlite3.connect(db_path)
conn.row_factory = sqlite3.Row
cur = conn.cursor()

conditions = []
params = []
if agent_f:
    conditions.append("agent = ?")
    params.append(agent_f)
if type_f:
    conditions.append("type = ?")
    params.append(type_f)

where = ("WHERE " + " AND ".join(conditions)) if conditions else ""
cur.execute(
    f"SELECT id, agent, project, type, name, description, created_at FROM agent_memories {where} ORDER BY agent, type, created_at",
    params
)
rows = [dict(r) for r in cur.fetchall()]
conn.close()

if json_out:
    print(json.dumps(rows, indent=2))
    sys.exit(0)

if not rows:
    print("No memories found.")
    sys.exit(0)

print(f"{'ID':<6} {'AGENT':<22} {'TYPE':<12} {'NAME':<30} CREATED")
print("-" * 90)
for r in rows:
    print(f"{r['id']:<6} {(r['agent'] or ''):<22} {(r['type'] or ''):<12} {(r['name'] or '')[:30]:<30} {(r['created_at'] or '')[:19]}")
PYEOF
}

_memory_forget() {
  _require_db
  local memory_id="${1:-}"
  if [ -z "$memory_id" ]; then
    _error "Usage: cast memory forget <memory-id>"
    return 1
  fi

  local rows_affected
  rows_affected="$(python3 - "$CAST_DB_PATH" "$memory_id" <<'PYEOF'
import sys, sqlite3
db_path, mem_id = sys.argv[1], sys.argv[2]
conn = sqlite3.connect(db_path)
cur = conn.cursor()
cur.execute("DELETE FROM agent_memories WHERE id=?", (mem_id,))
conn.commit()
print(cur.rowcount)
conn.close()
PYEOF
  )"

  if [ "${rows_affected:-0}" -eq 0 ]; then
    _warn "Memory $memory_id not found"
  else
    if [ "$CAST_JSON" -eq 1 ]; then
      printf '{"status":"deleted","id":"%s"}\n' "$memory_id"
    else
      _success "Memory $memory_id deleted"
    fi
  fi
}

_memory_export() {
  _require_db
  python3 - "$CAST_DB_PATH" <<'PYEOF'
import sys, sqlite3, json

db_path = sys.argv[1]
conn = sqlite3.connect(db_path)
conn.row_factory = sqlite3.Row
cur = conn.cursor()
cur.execute("SELECT id, agent, project, type, name, description, content, created_at, updated_at FROM agent_memories ORDER BY id")
rows = [dict(r) for r in cur.fetchall()]
conn.close()
print(json.dumps(rows, indent=2))
PYEOF
}

# ── Subcommand: budget ───────────────────────────────────────────────────────
_cmd_budget() {
  local show_week=0
  local project_filter=""

  while [ "${#}" -gt 0 ]; do
    case "$1" in
      --week)     show_week=1; shift ;;
      --project)  project_filter="${2:-}"; shift 2 ;;
      --help|-h)
        cat <<USAGE
Usage: cast budget [options]

  --week              Last 7 days grouped by date
  --project <name>    All-time spend for project
USAGE
        return 0
        ;;
      *) shift ;;
    esac
  done

  _require_db

  python3 - "$CAST_DB_PATH" "$show_week" "$project_filter" "$CAST_JSON" <<'PYEOF'
import sys, sqlite3, json
from datetime import datetime, timedelta, timezone

db_path, week_mode, project_f, json_mode = sys.argv[1:5]
show_week = week_mode == "1"
json_out = json_mode == "1"

conn = sqlite3.connect(db_path)
conn.row_factory = sqlite3.Row
cur = conn.cursor()

today = datetime.now(timezone.utc).strftime('%Y-%m-%d')
week_ago = (datetime.now(timezone.utc) - timedelta(days=7)).strftime('%Y-%m-%d')

cur.execute("SELECT COALESCE(SUM(cost_usd),0) FROM agent_runs WHERE DATE(started_at)=?", (today,))
today_spend = cur.fetchone()[0] or 0.0

cur.execute("SELECT COALESCE(SUM(cost_usd),0) FROM agent_runs WHERE DATE(started_at)>=?", (week_ago,))
week_spend = cur.fetchone()[0] or 0.0

cur.execute("SELECT COUNT(*) FROM agent_runs")
total_runs = cur.fetchone()[0] or 0

project_spend = None
if project_f:
    cur.execute("SELECT COALESCE(SUM(cost_usd),0) FROM agent_runs WHERE project=?", (project_f,))
    project_spend = cur.fetchone()[0] or 0.0

week_rows = []
if show_week:
    cur.execute(
        """SELECT DATE(started_at) as day, COALESCE(SUM(cost_usd),0) as spend
           FROM agent_runs WHERE DATE(started_at)>=? GROUP BY day ORDER BY day DESC""",
        (week_ago,)
    )
    week_rows = [{"date": r["day"], "spend": r["spend"]} for r in cur.fetchall()]

conn.close()

if json_out:
    out = {
        "today_usd": round(today_spend, 4),
        "week_usd": round(week_spend, 4),
        "total_runs": total_runs,
    }
    if project_f:
        out["project"] = project_f
        out["project_spend_usd"] = round(project_spend, 4)
    if show_week:
        out["week_breakdown"] = week_rows
    print(json.dumps(out, indent=2))
    sys.exit(0)

print(f"Today: ${today_spend:.2f}  |  This week: ${week_spend:.2f}  |  Total runs: {total_runs}")
if project_f:
    print(f"Project '{project_f}': ${project_spend:.2f} all-time")
if show_week and week_rows:
    print()
    print("Week breakdown:")
    for r in week_rows:
        print(f"  {r['date']}: ${r['spend']:.4f}")
elif show_week:
    print("No spend data for the last 7 days.")
PYEOF
}

# ── Subcommand: doctor ───────────────────────────────────────────────────────
_cmd_doctor() {
  local overall_ok=1

  local OK="[${C_GREEN}ok${C_RESET}]"
  local WARN="[${C_YELLOW}!!${C_RESET}]"
  local ERR="[${C_RED}ERR${C_RESET}]"
  local INFO="[${C_CYAN}--${C_RESET}]"

  printf "${C_BOLD}CAST Doctor${C_RESET}\n"
  printf "%s\n" "$(python3 -c "print('-' * 52)" 2>/dev/null || printf '%0.s-' {1..52})"

  # 1. cast.db accessible
  if sqlite3 "$CAST_DB_PATH" 'SELECT 1' >/dev/null 2>&1; then
    printf "%b cast.db accessible (%s)\n" "$OK" "$CAST_DB_PATH"
  else
    printf "%b cast.db not accessible (%s)\n" "$ERR" "$CAST_DB_PATH"
    overall_ok=0
    printf "\n  Run: bash %s/cast-db-init.sh\n" "$CAST_SCRIPTS_DIR"
    return 1
  fi

  # 2. Schema — 4 required tables
  local required_tables="sessions agent_runs agent_memories routing_events"
  local missing_tables=""
  local found_count=0
  for tbl in $required_tables; do
    if sqlite3 "$CAST_DB_PATH" "SELECT name FROM sqlite_master WHERE type='table' AND name='${tbl}';" 2>/dev/null | grep -q "${tbl}"; then
      found_count=$((found_count + 1))
    else
      missing_tables="${missing_tables} ${tbl}"
    fi
  done
  if [ -z "$missing_tables" ]; then
    printf "%b Schema: %d tables present\n" "$OK" "$found_count"
  else
    printf "%b Schema: %d/4 tables found — missing:%s\n" "$WARN" "$found_count" "$missing_tables"
    overall_ok=0
  fi

  # 3. Hooks registered
  local settings_file="${HOME}/.claude/settings.json"
  local hook_count=0
  if [ -f "$settings_file" ]; then
    hook_count="$(python3 - "$settings_file" <<'PYEOF'
import json, sys
try:
    with open(sys.argv[1]) as f:
        cfg = json.load(f)
    hooks = cfg.get("hooks", {})
    total = sum(len(v) if isinstance(v, list) else 1 for v in hooks.values())
    print(total)
except Exception:
    print(0)
PYEOF
    2>/dev/null || echo 0)"
  fi
  if [ "${hook_count:-0}" -gt 3 ]; then
    printf "%b Hooks registered: %d entries\n" "$OK" "$hook_count"
  else
    printf "%b Hooks registered: only %d entries found\n" "$WARN" "$hook_count"
    overall_ok=0
  fi

  # 4. Hook scripts exist
  if [ -f "$settings_file" ]; then
    local missing_scripts
    missing_scripts="$(python3 - "$settings_file" <<'PYEOF'
import json, sys, os

try:
    with open(sys.argv[1]) as f:
        cfg = json.load(f)
    hooks = cfg.get("hooks", {})
except Exception:
    sys.exit(0)

missing = []
interpreters = {"bash", "sh", "python3", "python", "node"}
for event, entries in hooks.items():
    if not isinstance(entries, list):
        entries = [entries]
    for entry in entries:
        inner = entry.get("hooks", []) if isinstance(entry, dict) else []
        for h in inner:
            if not isinstance(h, dict):
                continue
            cmd = h.get("command", "")
            if not cmd:
                continue
            for part in cmd.split():
                if part in interpreters or part.startswith("-"):
                    continue
                expanded = os.path.expanduser(part)
                if "/" in expanded and not os.path.isfile(expanded):
                    missing.append(expanded)
                break

for m in missing:
    print(m)
PYEOF
    2>/dev/null || echo "")"
    if [ -z "$missing_scripts" ]; then
      printf "%b Hook scripts: all found\n" "$OK"
    else
      while IFS= read -r script_path; do
        [ -z "$script_path" ] && continue
        printf "%b Hook script missing: %s\n" "$ERR" "$script_path"
        overall_ok=0
      done <<< "$missing_scripts"
    fi
  fi

  # 5. Events dir writable
  local events_dir="${HOME}/.claude/cast/events"
  if [ -d "$events_dir" ] && [ -w "$events_dir" ]; then
    printf "%b Events dir writable\n" "$OK"
  elif [ -d "$events_dir" ]; then
    printf "%b Events dir not writable: %s\n" "$WARN" "$events_dir"
    overall_ok=0
  else
    printf "%b Events dir missing: %s\n" "$WARN" "$events_dir"
    overall_ok=0
  fi

  # 6. Agent count
  local agent_count=0
  if [ -d "$CAST_AGENTS_DIR" ]; then
    agent_count="$(ls "$CAST_AGENTS_DIR"/*.md 2>/dev/null | wc -l | tr -d ' ')"
  fi
  printf "%b Agents: %d installed\n" "$INFO" "$agent_count"

  # 7. BATS available
  if command -v bats >/dev/null 2>&1; then
    printf "%b BATS available\n" "$OK"
  else
    printf "%b BATS not found (install: brew install bats-core)\n" "$WARN"
    overall_ok=0
  fi

  # 8. Version
  printf "%b Version: %s\n" "$INFO" "$CAST_VERSION"

  # Summary
  printf "%s\n" "$(python3 -c "print('-' * 52)" 2>/dev/null || printf '%0.s-' {1..52})"
  if [ "$overall_ok" -eq 1 ]; then
    printf "%b All checks passed\n" "$OK"
  else
    printf "%b Some checks need attention\n" "$WARN"
  fi
}

# ── Subcommand: exec ─────────────────────────────────────────────────────────
_cmd_exec() {
  local mode_flag=""
  local plan_file=""

  while [ "${#}" -gt 0 ]; do
    case "$1" in
      --resume) mode_flag="--resume"; shift ;;
      --status) mode_flag="--status"; shift ;;
      --help|-h)
        cat <<USAGE
Usage: cast exec [--resume | --status] <plan-file>

  <plan-file>            Execute all batches defined in the plan manifest
  --resume <plan-file>   Skip completed batches, resume from first non-complete
  --status <plan-file>   Print current checkpoint state and exit
USAGE
        return 0
        ;;
      -*)
        _error "Unknown flag: $1"
        return 1
        ;;
      *)
        if [ -z "$plan_file" ]; then
          plan_file="$1"
        else
          _error "Unexpected argument: $1"
          return 1
        fi
        shift
        ;;
    esac
  done

  if [ -z "$plan_file" ]; then
    _error "Plan file is required."
    printf "  Usage: cast exec [--resume|--status] <plan-file>\n" >&2
    return 1
  fi

  local exec_script="${CAST_SCRIPTS_DIR}/cast-exec.sh"
  if [ ! -f "$exec_script" ]; then
    exec_script="${CAST_REPO_DIR}/scripts/cast-exec.sh"
  fi
  if [ ! -f "$exec_script" ]; then
    _error "cast-exec.sh not found"
    return 1
  fi

  if [ -n "$mode_flag" ]; then
    bash "$exec_script" "$mode_flag" "$plan_file"
  else
    bash "$exec_script" "$plan_file"
  fi
}

# ── Subcommand: install-completions ──────────────────────────────────────────
_cmd_install_completions() {
  local completions_src="${CAST_REPO_DIR}/completions"

  if [ ! -d "$completions_src" ]; then
    _warn "Completions directory not found: $completions_src"
    return 1
  fi

  local zsh_installed=0
  local bash_installed=0

  local zsh_comp="${completions_src}/_cast"
  if [ -f "$zsh_comp" ]; then
    local zsh_dir="${HOME}/.zsh/completions"
    mkdir -p "$zsh_dir"
    cp "$zsh_comp" "${zsh_dir}/_cast"
    zsh_installed=1
    _success "zsh completion installed: ${zsh_dir}/_cast"
    _info "  Add to ~/.zshrc: fpath=(~/.zsh/completions \$fpath) && autoload -U compinit && compinit"
  fi

  local bash_comp="${completions_src}/cast.bash"
  if [ -f "$bash_comp" ]; then
    local bash_dir="${HOME}/.bash_completion.d"
    mkdir -p "$bash_dir"
    cp "$bash_comp" "${bash_dir}/cast"
    bash_installed=1
    _success "bash completion installed: ${bash_dir}/cast"
    _info "  Add to ~/.bashrc: source ~/.bash_completion.d/cast"
  fi

  if [ "$zsh_installed" -eq 0 ] && [ "$bash_installed" -eq 0 ]; then
    _warn "No completion files found in $completions_src"
    return 1
  fi
}

# ── Main dispatch ────────────────────────────────────────────────────────────
if [ "$#" -gt 0 ]; then
  CAST_ARGS=("$@")
else
  CAST_ARGS=()
fi
if [ "${#CAST_ARGS[@]}" -gt 0 ]; then
  _parse_global_flags "${CAST_ARGS[@]}"
else
  _parse_global_flags
fi
if [ "${#CAST_ARGS[@]}" -gt 0 ]; then
  set -- "${CAST_ARGS[@]}"
else
  set --
fi

SUBCOMMAND="${1:-}"
shift 2>/dev/null || true

case "$SUBCOMMAND" in
  status)               _cmd_status "$@" ;;
  exec)                 _cmd_exec "$@" ;;
  memory)               _cmd_memory "$@" ;;
  budget)               _cmd_budget "$@" ;;
  agents)               _cmd_agents "$@" ;;
  hooks)                _cmd_hooks "$@" ;;
  doctor)               _cmd_doctor "$@" ;;
  install-completions)  _cmd_install_completions "$@" ;;
  ""|--help|-h)
    _usage
    exit 0
    ;;
  *)
    _error "Unknown subcommand: $SUBCOMMAND"
    printf "  Run: cast --help\n" >&2
    exit 1
    ;;
esac
