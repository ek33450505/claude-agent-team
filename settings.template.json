{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "_permissions_warning": "REVIEW CAREFULLY: Bash/Write/Edit let Claude act without asking. Remove any you're not comfortable with.",
  "permissions": {
    "allow": [
      "Bash",
      "Write",
      "Edit",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "bash ~/.claude/scripts/pre-tool-guard.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "if": "Bash(curl *)",
            "command": "bash ~/.claude/scripts/cast-security-guard.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "if": "Bash(ssh *)",
            "command": "bash ~/.claude/scripts/cast-security-guard.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "if": "Bash(scp *)",
            "command": "bash ~/.claude/scripts/cast-security-guard.sh",
            "timeout": 3
          }
        ],
        "description": "CAST enforcement — git guard (pre-tool-guard.sh, git * only) + security advisory (cast-security-guard.sh, curl/ssh/scp only)"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/cast-security-guard.sh",
            "timeout": 3
          }
        ],
        "description": "CAST security advisory — flags sensitive file edits (Write/Edit tools)"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/route.sh",
            "timeout": 5
          }
        ],
        "description": "CAST routing — matches prompts and injects [CAST-DISPATCH] directives"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Agent|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/post-tool-hook.sh",
            "timeout": 10
          }
        ],
        "description": "CAST review — auto-formats code, injects [CAST-REVIEW] directive, logs agent dispatches, and triggers [CAST-DEBUG] on Bash non-zero exits"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/cast-cost-tracker.sh",
            "timeout": 5
          }
        ],
        "description": "CAST cost tracking — records token usage per tool call into cast.db sessions and agent_runs tables"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/cast-budget-alert.sh",
            "timeout": 3
          }
        ],
        "description": "CAST budget guard — injects [CAST-BUDGET-WARN] or [CAST-BUDGET-HARD-LIMIT] when daily spend threshold reached"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Before finishing: (1) Were code changes made without dispatching code-reviewer? (2) Were commits made without the commit agent? (3) Are there unpushed commits? Check with: git log @{u}..HEAD --oneline 2>/dev/null. If yes to any, dispatch the appropriate agent (code-reviewer, commit, or push) now."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/stop-hook.sh",
            "timeout": 5
          }
        ],
        "description": "CAST safety net — catches missed reviews/commits before session ends; auto-dispatches chain-reporter after multi-batch orchestrator sessions"
      }
    ]
  },
  "teammateMode": "in-process",
  "autoUpdatesChannel": "stable",
  "plansDirectory": "~/.claude/plans/",
  "worktree": {
    "symlinkDirectories": ["node_modules", ".cache", "dist"]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["git", "docker", "bq", "osascript"],
    "filesystem": {
      "denyRead": ["~/.aws/credentials", "~/.ssh/id_*", "~/.gnupg", "~/.claude/cast.db", "~/.claude/history.jsonl", "~/.claude/logs/**", "~/.claude/routing-log.jsonl"],
      "allowWrite": ["/tmp"]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "*.googleapis.com",
        "api.anthropic.com"
      ],
      "allowLocalBinding": true
    }
  }
}
